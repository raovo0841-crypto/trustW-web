# TrustEx Web — Example .env for Render

# Port (Render sets automatically, можно не указывать)
PORT=10000

# PostgreSQL connection string (замени на свою!)
DB_CONNECTION_STRING=postgres://user:password@host:port/dbname

# JWT secret (любой длинный секрет)
JWT_SECRET=your_jwt_secret_here

# Email (если используется)
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password

# CryptoBot (если используется)
CRYPTOBOT_TOKEN=your_cryptobot_token

# Telegram admin ID (если используется)
ADMIN_CHAT_ID=123456789

# Другие переменные по необходимости
