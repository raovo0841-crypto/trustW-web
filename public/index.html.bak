<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TrustEx — Главная</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js" defer></script>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="js/auth.js" defer></script>
    <script src="js/balance.js" defer></script>
    <style>
        :root{--bg:#0b0e11;--bg2:#1e2329;--bg3:#2b3139;--bg-card:#181a20;--bg-hover:#252930;--green:#0ecb81;--red:#f6465d;--yellow:#f0b90b;--text:#eaecef;--text2:#848e9c;--text3:#5e6673;--border:#2b2f36}
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}

        /* NAV */
        .topnav{display:none;height:56px;background:var(--bg);border-bottom:1px solid var(--border);padding:0 24px;align-items:center;position:sticky;top:0;z-index:100}
        .topnav-in{max-width:1400px;margin:0 auto;display:flex;align-items:center;width:100%;height:100%;gap:32px}
        .logo{display:flex;align-items:center;gap:8px;text-decoration:none;flex-shrink:0}
        .logo-m{width:28px;height:28px;background:var(--green);border-radius:6px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;color:var(--bg)}
        .logo-t{font-size:18px;font-weight:700;color:var(--text);letter-spacing:-.5px}.logo-t span{color:var(--green)}
        .navlinks{display:flex;gap:2px;flex:1}
        .navlinks a{text-decoration:none;color:var(--text2);font-size:14px;font-weight:500;padding:8px 14px;border-radius:4px;transition:all .1s}
        .navlinks a:hover{color:var(--text);background:var(--bg2)}
        .navlinks a.act{color:var(--text);background:var(--bg2)}
        .nav-user{display:flex;align-items:center;gap:12px;flex-shrink:0}
        .nav-email{font-size:13px;color:var(--text2);max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
        .nav-out{background:transparent;border:1px solid var(--border);color:var(--text2);padding:6px 14px;border-radius:4px;font-size:13px;cursor:pointer;font-family:'Inter',sans-serif;transition:all .1s}
        .nav-out:hover{color:var(--red);border-color:var(--red)}

        .mobnav{position:fixed;bottom:0;left:0;right:0;z-index:999;background:var(--bg);border-top:1px solid var(--border);padding:8px 0 max(10px,env(safe-area-inset-bottom));display:flex;justify-content:space-around;align-items:center}
        .mobnav a{display:flex;flex-direction:column;align-items:center;text-decoration:none;color:var(--text3);padding:4px 0;width:20%;font-size:10px;gap:2px;transition:color .1s}
        .mobnav a.act{color:var(--green)}
        .mobnav svg{width:22px;height:22px;fill:currentColor}

        /* TICKER */
        .ticker{background:var(--bg);border-bottom:1px solid var(--border);overflow:hidden;padding:8px 0}
        .ticker-track{display:flex;gap:28px;animation:scroll 30s linear infinite;width:max-content}
        @keyframes scroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
        .tk-item{display:flex;align-items:center;gap:6px;white-space:nowrap;font-size:13px}
        .tk-sym{font-weight:600;color:var(--text)}.tk-price{color:var(--text2)}
        .tk-ch{font-size:12px;font-weight:500;padding:1px 6px;border-radius:3px}
        .tk-ch.up{color:var(--green);background:rgba(14,203,129,.1)}.tk-ch.down{color:var(--red);background:rgba(246,70,93,.1)}

        /* LAYOUT */
        .main{padding:16px 16px 80px}
        .layout{display:flex;flex-direction:column;gap:16px;max-width:560px;margin:0 auto}
        .panel{background:var(--bg-card);border:1px solid var(--border);border-radius:8px;padding:16px}
        .panel-h{font-size:14px;font-weight:600;margin-bottom:12px;display:flex;align-items:center;gap:8px;color:var(--text)}
        .panel-h svg{width:16px;height:16px;fill:var(--green)}

        /* MOBILE HEADER */
        .mob-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
        .mob-logo{display:flex;align-items:center;gap:8px}
        .mob-logo-m{width:32px;height:32px;background:var(--green);border-radius:6px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;color:var(--bg)}
        .mob-logo-t{font-size:18px;font-weight:700}.mob-logo-t span{color:var(--green)}
        .mob-acts{display:flex;gap:8px}
        .mob-btn{width:36px;height:36px;border-radius:6px;background:var(--bg-card);border:1px solid var(--border);color:var(--text2);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .1s}
        .mob-btn:hover{border-color:var(--green);color:var(--green)}
        .mob-btn svg{width:18px;height:18px;fill:currentColor}

        /* BALANCE */
        .bal-card{background:var(--bg-card);border:1px solid var(--border);border-radius:8px;padding:20px}
        .bal-label{color:var(--text2);font-size:13px;margin-bottom:6px;display:flex;align-items:center;gap:6px}
        .bal-label svg{width:16px;height:16px;fill:var(--green)}
        .bal-row{display:flex;align-items:center;gap:12px}
        .bal-amt{font-size:28px;font-weight:700;font-variant-numeric:tabular-nums;letter-spacing:-.5px}
        .bal-eye{width:28px;height:28px;border-radius:4px;background:var(--bg2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text2);flex-shrink:0}
        .bal-eye svg{width:16px;height:16px;fill:currentColor}
        .bal-hide{letter-spacing:2px}
        .quick{display:flex;gap:8px;margin-top:16px}
        .quick a{flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;text-decoration:none}
        .quick-ic{width:40px;height:40px;border-radius:6px;background:var(--bg2);border:1px solid var(--border);color:var(--text);display:flex;align-items:center;justify-content:center;transition:all .15s}
        .quick-ic:hover{background:var(--green);border-color:var(--green);color:var(--bg)}
        .quick-ic svg{width:18px;height:18px;fill:currentColor}
        .quick span{font-size:11px;color:var(--text2)}

        .skeleton{background:linear-gradient(90deg,var(--bg2) 25%,var(--bg3) 50%,var(--bg2) 75%);background-size:200% 100%;animation:sk 1.5s infinite;border-radius:4px;color:transparent!important}
        @keyframes sk{0%{background-position:200% 0}100%{background-position:-200% 0}}

        /* ASSETS */
        .asset{background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:12px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;transition:background .1s}
        .asset:hover{background:var(--bg-hover)}
        .asset:last-child{margin-bottom:0}
        .asset-l{display:flex;align-items:center;gap:10px;flex:1;min-width:0}
        .coin{width:32px;height:32px;min-width:32px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px}
        .coin-rub{background:#f0b90b;color:#000}.coin-eur{background:#3b82f6;color:#fff}.coin-byn{background:#dc2626;color:#fff}
        .coin-btc{background:#f7931a;color:#fff}.coin-eth{background:#627eea;color:#fff}.coin-ton{background:#0088cc;color:#fff}.coin-usdt{background:#26a17b;color:#fff}
        .asset-name{font-weight:600;font-size:13px}.asset-sub{font-size:11px;color:var(--text3);margin-top:1px}
        .asset-r{text-align:right;flex-shrink:0;margin-left:12px}
        .asset-bal{font-weight:600;font-size:13px;font-variant-numeric:tabular-nums}.asset-eq{font-size:11px;color:var(--text3);margin-top:1px}

        /* PROFILE/STATS */
        .info-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px}
        .info-row:last-child{border-bottom:none}
        .info-row-l{color:var(--text2)}.info-row-v{font-weight:600}

        /* ANALYTICS */
        .per-btns{display:flex;gap:4px;margin-bottom:12px;flex-wrap:wrap}
        .per-btn{background:var(--bg);border:1px solid var(--border);color:var(--text2);padding:5px 10px;border-radius:4px;font-size:12px;font-weight:500;cursor:pointer;font-family:'Inter',sans-serif;transition:all .1s}
        .per-btn:hover{border-color:var(--green);color:var(--text)}
        .per-btn.active{background:var(--green);border-color:var(--green);color:var(--bg)}
        .s-row{background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:8px 12px;margin-bottom:4px;display:flex;justify-content:space-between;align-items:center;font-size:12px}
        .s-row:last-child{margin-bottom:0}
        .s-row-l{color:var(--text2)}.s-row-v{font-weight:600}
        .tg{color:var(--green)}.tr{color:var(--red)}

        /* PERIOD */
        .per-box{background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:12px;margin-bottom:6px}
        .per-box:last-child{margin-bottom:0}
        .per-box-nm{font-size:12px;font-weight:600;color:var(--green);margin-bottom:6px}
        .per-box-r{display:flex;justify-content:space-between;margin-bottom:2px;font-size:12px}
        .per-box-r:last-child{margin-bottom:0}
        .per-box-l{color:var(--text2)}.per-box-v{font-weight:600}
        .per-box-v small{color:var(--text3);font-weight:400;margin-left:4px;font-size:10px}

        /* REVIEWS */
        .rv-card{background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:12px;display:none}
        .rv-card.active{display:block;animation:fi .3s}
        @keyframes fi{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
        .rv-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px}
        .rv-name{font-weight:600;font-size:13px}.rv-date{font-size:11px;color:var(--text3)}
        .rv-stars{color:var(--yellow);font-size:13px;margin-bottom:4px}
        .rv-text{font-size:12px;color:var(--text2);line-height:1.5}
        .rv-nav{display:flex;gap:4px;margin-bottom:8px}
        .rv-btn{width:28px;height:28px;border-radius:4px;border:1px solid var(--border);background:var(--bg);color:var(--text2);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:12px;transition:all .1s}
        .rv-btn:hover{border-color:var(--green);color:var(--green)}
        .rv-counter{font-size:11px;color:var(--text3)}
        .rv-link{color:var(--green);font-size:12px;font-weight:500;text-decoration:none}
        .rv-link:hover{text-decoration:underline}

        .fab{position:fixed;bottom:72px;right:16px;width:44px;height:44px;border-radius:8px;background:var(--green);border:none;cursor:pointer;z-index:100;display:flex;align-items:center;justify-content:center;color:var(--bg);transition:opacity .15s}
        .fab:hover{opacity:.85}
        .fab svg{width:20px;height:20px;fill:currentColor}

        @media(min-width:768px){
            .mobnav{display:none!important}.topnav{display:flex}.mob-head{display:none}
            .main{padding:24px}
            .fab{bottom:24px;right:24px}
            .layout{flex-direction:row;max-width:1280px;align-items:flex-start}
            .side-l{width:260px;flex-shrink:0;display:flex;flex-direction:column;gap:12px;position:sticky;top:72px}
            .center{flex:1;min-width:0;display:flex;flex-direction:column;gap:12px}
            .side-r{width:300px;flex-shrink:0;display:flex;flex-direction:column;gap:12px;position:sticky;top:72px}
            .bal-amt{font-size:32px}
        }
        @media(min-width:1200px){.side-l{width:280px}.side-r{width:320px}}
        @media(max-width:767px){.side-l,.side-r{display:none}.center{width:100%}.layout{max-width:100%}}
        @media(min-width:768px) and (max-width:1023px){.side-l{display:none}.side-r{width:260px}.layout{max-width:960px}}
    </style>
</head>
<body>

<nav class="topnav"><div class="topnav-in">
    <a href="/" class="logo"><div class="logo-m">T</div><div class="logo-t">Trust<span>Ex</span></div></a>
    <div class="navlinks">
        <a href="/" class="act">Обзор</a><a href="trading.html">Торговля</a><a href="exchange.html">Обмен</a>
        <a href="wallet.html">Активы</a><a href="deposit.html">Депозит</a><a href="withdraw.html">Вывод</a><a href="profile.html">Профиль</a>
    </div>
    <div class="nav-user"><span class="nav-email" id="navUserEmail"></span><button class="nav-out" onclick="Auth.logout()">Выйти</button></div>
</div></nav>

<div class="ticker"><div class="ticker-track" id="tickerTrack">
    <div class="tk-item"><span class="tk-sym">BTC</span><span class="tk-price" id="tickerBtcPrice">$—</span><span class="tk-ch up" id="tickerBtcChange">0.00%</span></div>
    <div class="tk-item"><span class="tk-sym">ETH</span><span class="tk-price" id="tickerEthPrice">$—</span><span class="tk-ch up" id="tickerEthChange">0.00%</span></div>
    <div class="tk-item"><span class="tk-sym">TON</span><span class="tk-price" id="tickerTonPrice">$—</span><span class="tk-ch up" id="tickerTonChange">0.00%</span></div>
    <div class="tk-item"><span class="tk-sym">SOL</span><span class="tk-price" id="tickerSolPrice">$—</span><span class="tk-ch up" id="tickerSolChange">0.00%</span></div>
    <div class="tk-item"><span class="tk-sym">XRP</span><span class="tk-price" id="tickerXrpPrice">$—</span><span class="tk-ch up" id="tickerXrpChange">0.00%</span></div>
    <div class="tk-item"><span class="tk-sym">BTC</span><span class="tk-price" id="tickerBtcPrice2">$—</span><span class="tk-ch up" id="tickerBtcChange2">0.00%</span></div>
    <div class="tk-item"><span class="tk-sym">ETH</span><span class="tk-price" id="tickerEthPrice2">$—</span><span class="tk-ch up" id="tickerEthChange2">0.00%</span></div>
    <div class="tk-item"><span class="tk-sym">TON</span><span class="tk-price" id="tickerTonPrice2">$—</span><span class="tk-ch up" id="tickerTonChange2">0.00%</span></div>
    <div class="tk-item"><span class="tk-sym">SOL</span><span class="tk-price" id="tickerSolPrice2">$—</span><span class="tk-ch up" id="tickerSolChange2">0.00%</span></div>
    <div class="tk-item"><span class="tk-sym">XRP</span><span class="tk-price" id="tickerXrpPrice2">$—</span><span class="tk-ch up" id="tickerXrpChange2">0.00%</span></div>
</div></div>

<button class="fab" onclick="location.href='support.html'"><svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/></svg></button>

<div class="main">
    <div class="mob-head">
        <div class="mob-logo"><div class="mob-logo-m">T</div><div class="mob-logo-t">Trust<span>Ex</span></div></div>
        <div class="mob-acts">
            <button class="mob-btn" onclick="location.href='exchange.html'"><svg viewBox="0 0 24 24"><path d="M6.99 11L3 15l3.99 4v-3H14v-2H6.99v-3zM21 9l-3.99-4v3H10v2h7.01v3L21 9z"/></svg></button>
            <button class="mob-btn" onclick="Auth.logout()"><svg viewBox="0 0 24 24"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg></button>
        </div>
    </div>

    <div class="layout">
        <!-- LEFT -->
        <div class="side-l">
            <div class="panel">
                <div class="panel-h"><svg viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg> Профиль</div>
                <div class="info-row"><span class="info-row-l">Email</span><span class="info-row-v" id="userEmailDisplay">—</span></div>
                <div class="info-row"><span class="info-row-l">Сделки</span><span class="info-row-v" id="stats">0 / <span class="tg">0</span> / <span class="tr">0</span></span></div>
                <div class="info-row"><span class="info-row-l">Объем</span><span class="info-row-v" id="tradingVolume">0.00 USDT</span></div>
            </div>
            <div class="panel">
                <div class="panel-h"><svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg> Отзывы</div>
                <div class="rv-nav"><button class="rv-btn" id="prevReview">←</button><button class="rv-btn" id="nextReview">→</button></div>
                <div id="reviewsContainer"></div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px"><span class="rv-counter" id="reviewCounter">1 из 48</span><a href="reviews.html" class="rv-link">Все отзывы →</a></div>
            </div>
            <div class="panel">
                <div class="panel-h"><svg viewBox="0 0 24 24"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11z"/></svg> По периодам</div>
                <div class="per-box"><div class="per-box-nm">Сегодня</div><div class="per-box-r"><span class="per-box-l">Прибыль</span><span class="per-box-v tg" id="pProfitToday">+0.00</span></div><div class="per-box-r"><span class="per-box-l">Сделок</span><span class="per-box-v" id="pTradesToday">0</span></div></div>
                <div class="per-box"><div class="per-box-nm">Неделя</div><div class="per-box-r"><span class="per-box-l">Прибыль</span><span class="per-box-v tg" id="pProfitWeek">+0.00</span></div><div class="per-box-r"><span class="per-box-l">Сделок</span><span class="per-box-v" id="pTradesWeek">0</span></div></div>
                <div class="per-box"><div class="per-box-nm">Месяц</div><div class="per-box-r"><span class="per-box-l">Прибыль</span><span class="per-box-v tg" id="pProfitMonth">+0.00</span></div><div class="per-box-r"><span class="per-box-l">Сделок</span><span class="per-box-v" id="pTradesMonth">0</span></div></div>
            </div>
        </div>

        <!-- CENTER -->
        <div class="center">
            <div class="bal-card">
                <div class="bal-label"><svg viewBox="0 0 24 24"><path d="M21 18v1c0 1.1-.9 2-2 2H5c-1.11 0-2-.9-2-2V5c0-1.1.89-2 2-2h14c1.1 0 2 .9 2 2v1h-9c-1.11 0-2 .9-2 2v8c0 1.1.89 2 2 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg> Общий баланс</div>
                <div class="bal-row">
                    <div class="bal-amt skeleton" id="totalBalance">$0000.00</div>
                    <button class="bal-eye" id="balanceToggle" onclick="toggleBalanceVisibility()"><svg id="eyeIcon" viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg></button>
                </div>
                <div class="quick">
                    <a href="deposit.html"><div class="quick-ic"><svg viewBox="0 0 24 24"><path d="M4 12l1.41 1.41L11 7.83V20h2V7.83l5.58 5.59L20 12l-8-8-8 8z"/></svg></div><span>Депозит</span></a>
                    <a href="withdraw.html"><div class="quick-ic"><svg viewBox="0 0 24 24"><path d="M20 12l-1.41-1.41L13 16.17V4h-2v12.17l-5.58-5.59L4 12l8 8 8-8z"/></svg></div><span>Вывод</span></a>
                    <a href="exchange.html"><div class="quick-ic"><svg viewBox="0 0 24 24"><path d="M6.99 11L3 15l3.99 4v-3H14v-2H6.99v-3zM21 9l-3.99-4v3H10v2h7.01v3L21 9z"/></svg></div><span>Обмен</span></a>
                    <a href="trading.html"><div class="quick-ic"><svg viewBox="0 0 24 24"><path d="M3.5 18.49l6-6.01 4 4L22 6.92l-1.41-1.41-7.09 7.97-4-4L2 16.99z"/></svg></div><span>Торговля</span></a>
                </div>
            </div>

            <div class="panel">
                <div class="panel-h"><svg viewBox="0 0 24 24"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg> Валюты</div>
                <div class="asset"><div class="asset-l"><div class="coin coin-rub">₽</div><div><div class="asset-name">RUB</div><div class="asset-sub">Рубль</div></div></div><div class="asset-r"><div class="asset-bal skeleton" id="rubBalance">0.00</div><div class="asset-eq" id="rubEquiv">≈ $0.00</div></div></div>
                <div class="asset"><div class="asset-l"><div class="coin coin-eur">€</div><div><div class="asset-name">EUR</div><div class="asset-sub">Euro</div></div></div><div class="asset-r"><div class="asset-bal skeleton" id="eurBalance">0.00</div><div class="asset-eq" id="eurEquiv">≈ $0.00</div></div></div>
                <div class="asset"><div class="asset-l"><div class="coin coin-byn">Br</div><div><div class="asset-name">BYN</div><div class="asset-sub">Бел. рубль</div></div></div><div class="asset-r"><div class="asset-bal skeleton" id="bynBalance">0.00</div><div class="asset-eq" id="bynEquiv">≈ $0.00</div></div></div>
            </div>

            <div class="panel">
                <div class="panel-h"><svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.41 16.09V20h-2.67v-1.93c-1.71-.36-3.16-1.46-3.27-3.4h1.96c.1 1.05.82 1.87 2.65 1.87 1.96 0 2.4-.98 2.4-1.59 0-.83-.44-1.61-2.67-2.14-2.48-.6-4.18-1.62-4.18-3.67 0-1.72 1.39-2.84 3.11-3.21V4h2.67v1.95c1.86.45 2.79 1.86 2.85 3.39H14.3c-.05-1.11-.64-1.87-2.22-1.87-1.5 0-2.4.68-2.4 1.64 0 .84.65 1.39 2.67 1.91s4.18 1.39 4.18 3.91c-.01 1.83-1.38 2.83-3.12 3.16z"/></svg> Криптовалюты</div>
                <div class="asset"><div class="asset-l"><div class="coin coin-btc">₿</div><div><div class="asset-name">BTC</div><div class="asset-sub" id="btcPrice">—</div></div></div><div class="asset-r"><div class="asset-bal skeleton" id="btcBalance">0.0000</div><div class="asset-eq" id="btcEquiv">≈ $0.00</div></div></div>
                <div class="asset"><div class="asset-l"><div class="coin coin-eth">Ξ</div><div><div class="asset-name">ETH</div><div class="asset-sub" id="ethPrice">—</div></div></div><div class="asset-r"><div class="asset-bal skeleton" id="ethBalance">0.0000</div><div class="asset-eq" id="ethEquiv">≈ $0.00</div></div></div>
                <div class="asset"><div class="asset-l"><div class="coin coin-ton">T</div><div><div class="asset-name">TON</div><div class="asset-sub" id="tonPrice">—</div></div></div><div class="asset-r"><div class="asset-bal skeleton" id="tonBalance">0.0000</div><div class="asset-eq" id="tonEquiv">≈ $0.00</div></div></div>
                <div class="asset"><div class="asset-l"><div class="coin coin-usdt">₮</div><div><div class="asset-name">USDT</div><div class="asset-sub">$1.00</div></div></div><div class="asset-r"><div class="asset-bal skeleton" id="usdtBalance">0.00</div><div class="asset-eq" id="usdtEquiv">≈ $0.00</div></div></div>
            </div>

            <div class="panel" style="display:none" id="mobileProfile">
                <div class="panel-h"><svg viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg> Профиль</div>
                <div class="info-row"><span class="info-row-l">Email</span><span class="info-row-v" id="userEmailDisplay2">—</span></div>
                <div class="info-row"><span class="info-row-l">Сделки</span><span class="info-row-v" id="stats2">0 / <span class="tg">0</span> / <span class="tr">0</span></span></div>
                <div class="info-row"><span class="info-row-l">Объем</span><span class="info-row-v" id="tradingVolume2">0.00 USDT</span></div>
            </div>
        </div>

        <!-- RIGHT -->
        <div class="side-r">
            <div class="panel">
                <div class="panel-h"><svg viewBox="0 0 24 24"><path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"/></svg> Аналитика</div>
                <div class="per-btns">
                    <button class="per-btn active" onclick="selectPeriod(this,'all')">Все</button>
                    <button class="per-btn" onclick="selectPeriod(this,'year')">Год</button>
                    <button class="per-btn" onclick="selectPeriod(this,'month')">Мес</button>
                    <button class="per-btn" onclick="selectPeriod(this,'week')">Нед</button>
                    <button class="per-btn" onclick="selectPeriod(this,'day')">День</button>
                </div>
                <div class="s-row"><span class="s-row-l">Win Rate</span><span class="s-row-v" id="winRate">0.0%</span></div>
                <div class="s-row"><span class="s-row-l">Ср. прибыль</span><span class="s-row-v tg" id="avgProfit">+0.00</span></div>
                <div class="s-row"><span class="s-row-l">Ср. убыток</span><span class="s-row-v tr" id="avgLoss">0.00</span></div>
                <div class="s-row"><span class="s-row-l">Макс. прибыль</span><span class="s-row-v tg" id="maxWin">+0.00</span></div>
                <div class="s-row"><span class="s-row-l">Макс. убыток</span><span class="s-row-v tr" id="maxLoss">0.00</span></div>
                <div class="s-row"><span class="s-row-l">Profit Factor</span><span class="s-row-v" id="profitFactor">0.00</span></div>
            </div>
            <div class="panel">
                <div class="panel-h"><svg viewBox="0 0 24 24"><path d="M3.5 18.49l6-6.01 4 4L22 6.92l-1.41-1.41-7.09 7.97-4-4L2 16.99z"/></svg> P&L</div>
                <div id="pnlChartContainer" style="height:180px;position:relative">
                    <canvas id="pnlChart"></canvas>
                    <div id="pnlChartPlaceholder" style="position:absolute;top:0;left:0;right:0;bottom:0;display:flex;align-items:center;justify-content:center;color:var(--text3);font-size:12px">Нет данных</div>
                </div>
            </div>
        </div>
    </div>
</div>

<nav class="mobnav">
    <a href="index.html" class="act"><svg viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>Главная</a>
    <a href="trading.html"><svg viewBox="0 0 24 24"><path d="M3.5 18.49l6-6.01 4 4L22 6.92l-1.41-1.41-7.09 7.97-4-4L2 16.99z"/></svg>Торговля</a>
    <a href="exchange.html"><svg viewBox="0 0 24 24"><path d="M6.99 11L3 15l3.99 4v-3H14v-2H6.99v-3zM21 9l-3.99-4v3H10v2h7.01v3L21 9z"/></svg>Обмен</a>
    <a href="wallet.html"><svg viewBox="0 0 24 24"><path d="M21 18v1c0 1.1-.9 2-2 2H5c-1.11 0-2-.9-2-2V5c0-1.1.89-2 2-2h14c1.1 0 2 .9 2 2v1h-9c-1.11 0-2 .9-2 2v8c0 1.1.89 2 2 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>Активы</a>
    <a href="profile.html"><svg viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>Профиль</a>
</nav>

<script>
document.addEventListener('DOMContentLoaded', function() {
    if (!Auth.requireAuth()) return;
    var user = Auth.getUser();
    if (user && user.email) { var el = document.getElementById('navUserEmail'); if (el) el.textContent = user.email; }
    if (window.innerWidth < 768) { var mp = document.getElementById('mobileProfile'); if (mp) mp.style.display = ''; }
    window.addEventListener('resize', function() { var mp = document.getElementById('mobileProfile'); if (mp) mp.style.display = window.innerWidth < 768 ? '' : 'none'; });
    initBalanceVisibility(); renderReviews(); loadUserData(); updatePriceTicker(); loadAnalyticsData('all'); loadPeriodStats(); loadPnlChart(); setInterval(updatePriceTicker, 30000);
});

var updateEl = function(id, val) { var el = document.getElementById(id); if (el) el.textContent = val; };
var realBalance = '$0.00';
var isBalanceHidden = localStorage.getItem('balanceHidden') === 'true';
function initBalanceVisibility() { updateEyeIcon(); }
function toggleBalanceVisibility() { isBalanceHidden = !isBalanceHidden; localStorage.setItem('balanceHidden', isBalanceHidden); updateBalanceDisplay(); updateEyeIcon(); }
function updateBalanceDisplay() { var el = document.getElementById('totalBalance'); if (!el) return; if (isBalanceHidden) { el.textContent = '••••••'; el.classList.add('bal-hide'); } else { el.textContent = realBalance; el.classList.remove('bal-hide'); } }
function updateEyeIcon() { var e = document.getElementById('eyeIcon'); if (!e) return; e.innerHTML = isBalanceHidden ? '<path d="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/>' : '<path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>'; }
function setRealBalance(val) { realBalance = val; var el = document.getElementById('totalBalance'); if (el) el.classList.remove('skeleton'); updateBalanceDisplay(); }

async function updatePriceTicker() {
    try {
        var symbols = ["BTCUSDT","ETHUSDT","TONUSDT","SOLUSDT","XRPUSDT"];
        var res = await fetch('https://api.binance.com/api/v3/ticker/24hr?symbols=' + JSON.stringify(symbols));
        var tickers = await res.json(); var data = {};
        tickers.forEach(function(t) { data[t.symbol] = { price: parseFloat(t.lastPrice), change: parseFloat(t.priceChangePercent) }; });
        var setTicker = function(sym, p1, c1, p2, c2) {
            var d = data[sym + 'USDT']; if (!d) return;
            var price = d.price >= 100 ? '$' + d.price.toLocaleString('en-US', {maximumFractionDigits:2}) : '$' + d.price.toFixed(4);
            var change = d.change >= 0 ? '+' + d.change.toFixed(2) + '%' : d.change.toFixed(2) + '%';
            var cls = 'tk-ch ' + (d.change >= 0 ? 'up' : 'down');
            [p1,p2].forEach(function(id) { updateEl(id, price); });
            [c1,c2].forEach(function(id) { var el = document.getElementById(id); if (el) { el.textContent = change; el.className = cls; } });
        };
        setTicker('BTC','tickerBtcPrice','tickerBtcChange','tickerBtcPrice2','tickerBtcChange2');
        setTicker('ETH','tickerEthPrice','tickerEthChange','tickerEthPrice2','tickerEthChange2');
        setTicker('TON','tickerTonPrice','tickerTonChange','tickerTonPrice2','tickerTonChange2');
        setTicker('SOL','tickerSolPrice','tickerSolChange','tickerSolPrice2','tickerSolChange2');
        setTicker('XRP','tickerXrpPrice','tickerXrpChange','tickerXrpPrice2','tickerXrpChange2');
    } catch(e) {}
}

var cachedMarketPrices = JSON.parse(localStorage.getItem('trustex_market_prices') || 'null');
async function updateMarketPrices() {
    try {
        var priceMap = null;
        if (typeof BalanceManager !== 'undefined') { BalanceManager._rates = null; await BalanceManager.loadRates(); var rates = BalanceManager.getRates(); if (rates && rates.BTC) priceMap = { BTCUSDT: rates.BTC, ETHUSDT: rates.ETH, TONUSDT: rates.TON }; }
        if (!priceMap) { var r = await Auth.apiFetch('/api/exchange/rate'); if (r.ok) { var d = await r.json(); if (d && d.data && d.data.rates) { var rt = d.data.rates; priceMap = { BTCUSDT: rt.BTC, ETHUSDT: rt.ETH, TONUSDT: rt.TON }; } } }
        if (!priceMap) return null;
        updateEl('btcPrice', '$' + priceMap.BTCUSDT.toLocaleString()); updateEl('ethPrice', '$' + priceMap.ETHUSDT.toLocaleString()); updateEl('tonPrice', '$' + priceMap.TONUSDT.toFixed(2));
        return { btc: priceMap.BTCUSDT, eth: priceMap.ETHUSDT, ton: priceMap.TONUSDT };
    } catch(e) { return null; }
}

async function loadUserData() {
    try {
        if (typeof BalanceManager !== 'undefined') await BalanceManager.loadRates();
        var results = await Promise.all([Auth.apiFetch('/api/profile'), Auth.apiFetch('/api/trades/stats'), updateMarketPrices()]);
        var profileRes = results[0], statsRes = results[1], market = results[2];
        if (market) { cachedMarketPrices = market; localStorage.setItem('trustex_market_prices', JSON.stringify(market)); }
        var userData = null;
        if (profileRes.ok) {
            var pd = await profileRes.json(); userData = pd.data;
            if (userData) { updateEl('userEmailDisplay', userData.email || '—'); updateEl('userEmailDisplay2', userData.email || '—'); updateEl('tradingVolume', (parseFloat(userData.total_volume) || 0).toFixed(2) + ' USDT'); updateEl('tradingVolume2', (parseFloat(userData.total_volume) || 0).toFixed(2) + ' USDT'); }
        }
        try { if (statsRes.ok) { var sp = await statsRes.json(); var s = sp.data || {}; var html = (s.total_trades||0) + ' / <span class="tg">' + (s.wins||0) + '</span> / <span class="tr">' + (s.losses||0) + '</span>'; var el1 = document.getElementById('stats'); if (el1) el1.innerHTML = html; var el2 = document.getElementById('stats2'); if (el2) el2.innerHTML = html; } } catch(e) {}
        if (userData) {
            var bal = function(f) { return parseFloat(userData['balance_' + f] || userData[f]) || 0; };
            var m = market || cachedMarketPrices || { btc: 84000, eth: 3200, ton: 3.5 };
            var rubUsd = typeof BalanceManager !== 'undefined' ? BalanceManager.rubToUsd(bal('rub')) : bal('rub') * 0.012;
            var eurUsd = typeof BalanceManager !== 'undefined' ? BalanceManager.eurToUsd(bal('eur')) : bal('eur') * 1.089;
            var bynUsd = typeof BalanceManager !== 'undefined' ? BalanceManager.bynToUsd(bal('byn')) : bal('byn') * 0.3058;
            var btcUsd = bal('btc') * m.btc, ethUsd = bal('eth') * m.eth, tonUsd = bal('ton') * m.ton;
            var total = bal('usdt') + rubUsd + eurUsd + bynUsd + btcUsd + ethUsd + tonUsd;
            var fmt = function(n, d) { d = d || 2; return n.toLocaleString('ru-RU', {minimumFractionDigits:d, maximumFractionDigits:d}).replace(/,/g,'.'); };
            setRealBalance('$' + fmt(total));
            var setB = function(id, t) { var el = document.getElementById(id); if (el) { el.textContent = t; el.classList.remove('skeleton'); } };
            setB('rubBalance', fmt(bal('rub')) + ' ₽'); setB('eurBalance', fmt(bal('eur')) + ' €'); setB('bynBalance', fmt(bal('byn')) + ' Br');
            setB('btcBalance', bal('btc').toFixed(6) + ' BTC'); setB('tonBalance', bal('ton').toFixed(4) + ' TON'); setB('ethBalance', bal('eth').toFixed(6) + ' ETH'); setB('usdtBalance', fmt(bal('usdt')) + ' USDT');
            updateEl('rubEquiv', '≈ $' + fmt(rubUsd)); updateEl('eurEquiv', '≈ $' + fmt(eurUsd)); updateEl('bynEquiv', '≈ $' + fmt(bynUsd));
            updateEl('btcEquiv', '≈ $' + fmt(btcUsd)); updateEl('tonEquiv', '≈ $' + fmt(tonUsd)); updateEl('ethEquiv', '≈ $' + fmt(ethUsd)); updateEl('usdtEquiv', '≈ $' + fmt(bal('usdt')));
        }
    } catch(e) { console.error('[loadUserData]', e); }
}

function selectPeriod(btn, period) { document.querySelectorAll('.per-btn').forEach(function(b) { b.classList.remove('active'); }); btn.classList.add('active'); loadAnalyticsData(period); }
async function loadAnalyticsData(period) {
    try { var res = await Auth.apiFetch('/api/trades/analytics?period=' + (period||'all')); if (!res.ok) return; var p = await res.json(); var a = p.data || {}; var tt = parseInt(a.total_trades)||0, w = parseInt(a.wins)||0; var tp = parseFloat(a.total_profit)||0, tl = parseFloat(a.total_loss)||0;
        updateEl('winRate', (tt > 0 ? ((w/tt)*100).toFixed(1) : '0.0') + '%'); updateEl('avgProfit', '+' + (w > 0 ? (tp/w).toFixed(2) : '0.00')); updateEl('avgLoss', '-' + ((parseInt(a.losses)||0) > 0 ? (tl/parseInt(a.losses)).toFixed(2) : '0.00')); updateEl('maxWin', '+' + tp.toFixed(2)); updateEl('maxLoss', '-' + tl.toFixed(2)); updateEl('profitFactor', tl > 0 ? (tp/tl).toFixed(2) : '0.00');
    } catch(e) {}
}

async function loadPeriodStats() {
    var periods = ['day','week','month']; var map = { day: 'Today', week: 'Week', month: 'Month' };
    for (var i = 0; i < periods.length; i++) {
        try { var res = await Auth.apiFetch('/api/trades/analytics?period=' + periods[i]); if (res.ok) { var p = await res.json(); var a = p.data || {}; var profit = (parseFloat(a.total_profit)||0) - (parseFloat(a.total_loss)||0); var str = profit >= 0 ? '+' + profit.toFixed(2) : profit.toFixed(2); var cls = profit >= 0 ? 'per-box-v tg' : 'per-box-v tr'; var elP = document.getElementById('pProfit' + map[periods[i]]); var elT = document.getElementById('pTrades' + map[periods[i]]); if (elP) { elP.textContent = str; elP.className = cls; } if (elT) { elT.innerHTML = (a.total_trades||0) + ' <small>(' + (a.wins||0) + 'W / ' + (a.losses||0) + 'L)</small>'; } } } catch(e) {}
    }
}

var pnlChart = null;
async function loadPnlChart() {
    try {
        var res = await Auth.apiFetch('/api/trades/pnl-history'); if (!res.ok) return; var p = await res.json(); var history = p.data || [];
        var placeholder = document.getElementById('pnlChartPlaceholder'); var canvas = document.getElementById('pnlChart');
        if (history.length < 1) { placeholder.style.display = 'flex'; canvas.style.display = 'none'; return; }
        placeholder.style.display = 'none'; canvas.style.display = 'block';
        var cum = 0; var pts = history.map(function(h) { cum += parseFloat(h.pnl)||0; return { date: h.date, c: cum }; });
        var final = pts[pts.length-1].c || 0; var color = final >= 0 ? '#0ecb81' : '#f6465d';
        var gTop = final >= 0 ? 'rgba(14,203,129,0.4)' : 'rgba(246,70,93,0.4)'; var gBot = final >= 0 ? 'rgba(14,203,129,0)' : 'rgba(246,70,93,0)';
        var labels = pts.map(function(h) { var d = new Date(h.date); return String(d.getDate()).padStart(2,'0') + '.' + String(d.getMonth()+1).padStart(2,'0'); });
        var data = pts.map(function(h) { return h.c; });
        if (pnlChart) pnlChart.destroy(); var ctx = canvas.getContext('2d'); var grad = ctx.createLinearGradient(0,0,0,180); grad.addColorStop(0, gTop); grad.addColorStop(1, gBot);
        pnlChart = new Chart(ctx, { type:'line', data:{labels:labels,datasets:[{label:'P&L',data:data,borderColor:color,backgroundColor:grad,borderWidth:1.5,fill:true,tension:0.4,pointRadius:0,pointHoverRadius:4,pointHoverBackgroundColor:color}]}, options:{responsive:true,maintainAspectRatio:false,interaction:{intersect:false,mode:'index'},plugins:{legend:{display:false},tooltip:{backgroundColor:'#1e2329',titleColor:'#eaecef',bodyColor:color,borderColor:'#2b2f36',borderWidth:1,padding:8,displayColors:false,callbacks:{label:function(c){return (c.parsed.y>=0?'+':'')+c.parsed.y.toFixed(2)+' USDT'}}}},scales:{x:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#5e6673',font:{size:10},maxRotation:0,maxTicksLimit:5}},y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#5e6673',font:{size:10},callback:function(v){return(v>=0?'+':'')+v.toFixed(0)}}}}} });
    } catch(e) {}
}

var reviewIndex = 0;
var reviewNames = ['Алексей М.','Мария К.','Михаил Р.','Елена Ж.','Дмитрий Л.','Анна В.','Кирилл Б.','Ольга П.','Роман Т.','Наталья С.','Борис Х.','Марина Ц.','Тимур Д.','Алина Ф.','Константин Г.','Светлана Н.','Артём В.','Дарья Е.','Даниил К.','Полина О.','Андрей Ш.','Виктория З.','Иван Ф.','Екатерина Х.','Максим Р.','Александра Л.','Никита С.','Вероника Б.','Сергей Д.','Юлия Ж.','Григорий П.','София Т.','Павел А.','Валерия К.','Денис М.','Ксения В.','Владислав С.','Зоя Ф.','Олег Е.','Лилия Р.','Степан Г.','Арина Н.','Владимир Х.','Эмма Д.','Руслан Л.','Карина П.','Тарас Б.','Милана С.'];
var reviewTexts = ['Отличная платформа! Быстрые транзакции и интуитивный интерфейс. Рекомендую.','Использую TrustEx уже 3 месяца. Отличный опыт, поддержка отвечает быстро.','Лучшая торговая платформа. Низкие комиссии и надёжное исполнение.','Легко использовать даже новичкам. Мобильный интерфейс чистый и современный.','Выводы обрабатываются быстро. Очень доволен сервисом.','Профессиональная платформа с отличной безопасностью. Торгую здесь спокойно.','Новый дизайн огонь! Намного лучше, чем было. Так держать!','Конкурентные курсы и быстрый обмен. Буду продолжать использовать TrustEx.','Поддержка помогла решить проблему за пару часов. Впечатляет!','Простая регистрация и быстрая верификация. Начал торговать за минуты.','Инструменты графиков отличные. Идеально для технического анализа.','Быстрые депозиты и выводы. Проблем пока не было.','Хорошая ликвидность и узкие спреды. Профессиональный трейдинг.','Мобильное приложение работает отлично. Торгую на ходу без проблем.','Прозрачные комиссии без скрытых платежей. Честная платформа.','Бинарные опционы — супер функция. Легко прогнозировать и зарабатывать.','Сначала сомневался, но после полугода использования могу сказать — всё реально работает.','Наконец-то платформа, где вывод реально приходит, а не ждёшь неделю.','Друг посоветовал TrustEx, и я реально рад. Уже сделал первые сделки.','В целом неплохо. Был маленький вопрос с верификацией, но поддержка разобралась.','Пользуюсь больше года. Стабильно работает, курсы адекватные.','Перешёл с другой биржи и разница колоссальная. Тут всё удобнее.','Нравится, что всё чисто и понятно. Никакого мусора на экране.','Вчера впервые пополнил, всё прошло идеально!','Графики реально помогают. Можно нормально оценить ситуацию перед сделкой.','Два года торгую здесь — моя основная площадка. С выплатами ни разу не было проблем.','Поддержка ответила в 2 часа ночи. Ребята реально работают.','Попробовал кучу платформ перед TrustEx. Эта просто удобнее всех.','Задал вопрос по комиссиям — ответили буквально за 5 минут.','Интерфейс красивый, торги быстрые. Что ещё нужно?','Начал с маленькой суммы — всё сработало, пополнил уже нормально.','Не ожидал многого, но платформа реально хорошая. Сделки быстрые.','Порекомендовал коллегам. Трое из них уже зарегались.','Верификация заняла меньше дня. Быстрее любой другой площадки.','Курсы тут стабильно лучше, чем в других местах.','Кайф, что можно всё проверить с телефона. Мобильная версия на совесть.','Выводил дважды — оба раза быстро и без проблем.','Хорошая площадка для тех, кто не хочет сложных интерфейсов.','Почти два года пользуюсь. Ноль проблем. Для крипты это уже о чём-то говорит.','Больше всего ценю прозрачность. Видно чётко, за что платишь.','Только начал на прошлой неделе, но пока всё супер.','Надёжная платформа. Без лишних понтов. Просто работает.','Знакомый потерял деньги на другой бирже, перешёл сюда — небо и земля.','Всё грузится моментально, сделки проходят быстро.','В основном использую для обмена. Курсы всегда нормальные.','Лучшая команда поддержки в торговых приложениях.','Чисто, быстро, надёжно. Больше ничего не надо.','Недавно обновили — стало ещё лучше. Работает супер плавно.'];
var daysAgoList=[1,2,3,4,6,8,11,15,19,25,33,42,55,70,90,110,140,175,210,250,290,330,370,410,455,500,540,580,630,670,710,750,790,830,870,920,960,400,450,520,600,650,730,800,850,900,950,1000];
function daysToRel(d){if(d<=1)return '1 день назад';if(d<7)return d+' дн. назад';if(d<30){var w=Math.floor(d/7);return w+(w===1?' неделю':w<5?' недели':' недель')+' назад'}if(d<365){var m=Math.floor(d/30);return m+(m===1?' месяц':m<5?' месяца':' месяцев')+' назад'}var y=Math.floor(d/365);return y+(y===1?' год':y<5?' года':' лет')+' назад'}
var reviews=[];for(var ri=0;ri<48;ri++){reviews.push({name:reviewNames[ri],rating:ri<35?5:(ri<44?4:3),text:reviewTexts[ri],date:daysToRel(daysAgoList[ri])})}

function renderReviews() {
    var c = document.getElementById('reviewsContainer'); if (!c) return; var html = '';
    for (var i = 0; i < reviews.length; i++) { var r = reviews[i]; var stars = ''; for (var j = 0; j < r.rating; j++) stars += '★';
        html += '<div class="rv-card' + (i === reviewIndex ? ' active' : '') + '" id="review' + i + '"><div class="rv-head"><span class="rv-name">' + r.name + '</span><span class="rv-date">' + r.date + '</span></div><div class="rv-stars">' + stars + '</div><div class="rv-text">' + r.text + '</div></div>'; }
    c.innerHTML = html; updateEl('reviewCounter', (reviewIndex+1) + ' из ' + reviews.length);
}
function showReview(idx) { reviewIndex = idx; for (var i = 0; i < reviews.length; i++) { var el = document.getElementById('review' + i); if (el) el.classList.toggle('active', i === idx); } updateEl('reviewCounter', (idx+1) + ' из ' + reviews.length); }
document.getElementById('prevReview').onclick = function() { showReview(reviewIndex <= 0 ? reviews.length-1 : reviewIndex-1); };
document.getElementById('nextReview').onclick = function() { showReview(reviewIndex >= reviews.length-1 ? 0 : reviewIndex+1); };
</script>
</body>
</html>
